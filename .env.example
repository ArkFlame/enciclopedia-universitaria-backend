# Server
PORT=3594
NODE_ENV=production

# MySQL host auth
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=YOUR_REAL_PASSWORD

# Source legacy DB: do not change this
DB_NAME=enciclopediadb

# Target runtime DB: app reads from this after bootstrap
DRIZZLE_DB_NAME=enciclopediadb_drizzle

# Optional future-only vars for the refactor below.
# Safe to add now, but current runtime does not depend on them yet.
DATABASE_URL=mysql://root:YOUR_REAL_PASSWORD@localhost:3306/enciclopediadb_drizzle
LEGACY_DATABASE_URL=mysql://root:YOUR_REAL_PASSWORD@localhost:3306/enciclopediadb

# JWT
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d

# MercadoPago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Frontend
FRONTEND_URL=https://enciclopedia.arkflame.com

# Storage
STORAGE_PATH=/var/www/enciclopedia/storage
BASE_URL=https://api.enciclopedia.arkflame.com

# Subscription
SUBSCRIPTION_PRICE=1000
SUBSCRIPTION_CURRENCY=ARS

# Free limits
FREE_ARTICLES_PER_MONTH=5
FREE_SUBMISSIONS_PER_HOUR=1
FREE_EDITS_PER_HOUR=1
FREE_IMAGES_PER_HOUR=3

# Monthly limits
MONTHLY_SUBMISSIONS_PER_HOUR=10
MONTHLY_EDITS_PER_HOUR=10
MONTHLY_IMAGES_PER_HOUR=20

# Images
MAX_IMAGE_SIZE=5242880
COMPRESS_THRESHOLD=512000
WEBP_QUALITY=82

# Google OAuth
GOOGLE_CLIENT_ID=

# Email
RESEND_API_KEY=
EMAIL_FROM=Enciclopedia Universitaria <noreply@arkflame.com>

# AI
OPENROUTER_API_KEY=
AI_MODEL=arcee-ai/trinity-large-preview:free
AI_MAX_TOKENS=1500
AI_MAX_ITERATIONS=4
AI_RATE_LIMIT=20
